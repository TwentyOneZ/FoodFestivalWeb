SECRET_KEY=change-this-long-random-secret
SITE_URL=https://flavorsofbrazil.com
APP_PORT=6000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Local SQLite by default. For MySQL, use a URL like:
# DATABASE_URL=mysql+pymysql://db_user:db_password@localhost/db_name?charset=utf8mb4
DATABASE_URL=sqlite:///instance/flavors.db

FLASK_DEBUG=0
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
MAX_CONTENT_LENGTH=8388608

# Optional SMTP. If these are empty, applications are saved normally and email is skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ADMIN_NOTIFICATION_EMAIL=
